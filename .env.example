APP_NAME="Syscend Campus"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Freetown

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=syscend
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@syscend.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Gemini AI ───────────────────────────────────────────
# Free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── SMS Gateway (Vonage default, Twilio alternative) ────
# Credentials configured per-school via school_settings table
SMS_PROVIDER=vonage
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SENDER_ID=Syscend
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Orange Money (Mobile Money) ─────────────────────────
# Credentials configured per-school via school_settings table
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_API_USER=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_RETURN_URL="${APP_URL}/school/fees/payments/callback?method=orange_money"
ORANGE_MONEY_CANCEL_URL="${APP_URL}/school/fees/payments/callback?method=orange_money&status=cancelled"
ORANGE_MONEY_WEBHOOK_URL="${APP_URL}/api/v1/payments/webhook/orange-money"

# ─── Afrimoney (Mobile Money) ────────────────────────────
# Credentials configured per-school via school_settings table
AFRIMONEY_API_KEY=
AFRIMONEY_APP_ID=
AFRIMONEY_APP_SECRET=

# ─── Railway Deployment (optional overrides) ─────────────
# Railway auto-sets these, but you can override:
# RAILWAY_STATIC_URL=
# NPM_CONFIG_PRODUCTION=true
