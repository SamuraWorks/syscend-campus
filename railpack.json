{
    "$schema": "https://schema.railpack.com",
    "provider": "php",
    "buildAptPackages": [
        "libpng-dev",
        "libjpeg-dev",
        "libfreetype6-dev",
        "libgd-dev",
        "libpq-dev"
    ],
    "steps": {
        "build": {
            "commands": [
                "npm run build",
                "mkdir -p storage/framework/{sessions,views,cache,testing} storage/logs bootstrap/cache",
                "chmod -R a+rw storage"
            ]
        }
    }
}
