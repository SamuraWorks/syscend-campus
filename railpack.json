{
    "$schema": "https://schema.railpack.com",
    "provider": "php",
    "packages": {
        "php": "8.4"
    },
    "buildAptPackages": [
        "libpng-dev",
        "libjpeg-dev",
        "libfreetype6-dev",
        "libgd-dev"
    ],
    "secrets": [
        "APP_KEY",
        "DB_HOST",
        "DB_PORT",
        "DB_DATABASE",
        "DB_USERNAME",
        "DB_PASSWORD",
        "GEMINI_API_KEY"
    ],
    "steps": {
        "install": {
            "commands": [
                "composer install --no-dev --no-interaction --prefer-dist --optimize-autoloader",
                "npm ci"
            ]
        },
        "build": {
            "inputs": [{ "step": "install" }],
            "commands": [
                "npm run build",
                "php artisan config:cache",
                "php artisan route:cache",
                "php artisan view:cache"
            ]
        }
    },
    "deploy": {
        "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT"
    }
}
